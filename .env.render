# Environment Configuration for Render Deployment
# Copy these variables to your Render service environment settings

# Application Configuration
NODE_ENV=production
ENVIRONMENT=production
PORT=10000

# Database Configuration
# Replace with your PostgreSQL connection string from Render or external provider
DATABASE_URL=postgresql://username:password@host:port/database_name

# Authentication
# Generate a secure random string for JWT signing
JWT_SECRET_KEY=your-super-secure-random-jwt-secret-key-here

# Google Ads API Configuration
# Obtain these from Google Cloud Console
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token
GOOGLE_ADS_LOGIN_CUSTOMER_ID=your-google-ads-login-customer-id
GOOGLE_ADS_READ_ONLY=true  # Enforce reporting-only permissible use


# AI Integration
# Get from OpenRouter dashboard
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Database connection details (if using separate database service)
# PGHOST=your-postgres-host
# PGPORT=5432
# PGUSER=your-postgres-user
# PGPASSWORD=your-postgres-password
# PGDATABASE=your-postgres-database